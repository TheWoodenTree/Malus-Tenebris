[sub_resource type="Shader" id="Shader_2vfyf"]
resource_local_to_scene = true
code = "shader_type spatial;
render_mode cull_front;

uniform float outlineSize = 0.02;
uniform vec3 outlineColor : source_color = vec3(0.961, 0.608, 0.353);
uniform bool outlineOn = false;
uniform bool transparent = false;

void vertex()
{
	if (outlineOn)
		VERTEX += NORMAL * outlineSize;
}


void fragment()
{
	if (outlineOn)
		ALBEDO = outlineColor;
	if (transparent && !outlineOn)
		ALPHA = 0.0;
}


void light()
{
	if (outlineOn)
	{
		DIFFUSE_LIGHT = vec3(1.0, 1.0, 1.0);
	}
}"
