[gd_resource type="Shader" format=3 uid="uid://dxqqybmfd8gqf"]

[resource]
code = "shader_type canvas_item;

uniform sampler2D SCREEN_TEXTURE : hint_screen_texture, filter_linear_mipmap;

uniform vec4 color : source_color;
uniform float intensity = 10.0;

void fragment()
{
    float xDist = (UV.x - 0.5);
    float yDist = (UV.y - 0.5);

    float xOffset = xDist * intensity * SCREEN_PIXEL_SIZE.x;
    float yOffset = yDist * intensity * SCREEN_PIXEL_SIZE.y;

    // Base sample
    vec4 baseColor = texture(SCREEN_TEXTURE, SCREEN_UV);

    // Ghost samples (inwards and outwards from center)
    vec4 ghost1 = texture(SCREEN_TEXTURE, vec2(SCREEN_UV.x + xOffset, SCREEN_UV.y + yOffset));
    vec4 ghost2 = texture(SCREEN_TEXTURE, vec2(SCREEN_UV.x - xOffset, SCREEN_UV.y - yOffset));

    // Blend them all together
    COLOR = (baseColor * 0.6) + (ghost1 * 0.2) + (ghost2 * 0.2);
}
"
metadata/_edit_res_path = "res://source/assets/shaders/vignette_shader.tres"
