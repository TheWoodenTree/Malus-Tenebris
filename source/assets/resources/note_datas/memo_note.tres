[resource]
script = ExtResource("1_oev5b")
title = "Guard Relocation Memo"
text = "Effective immediately: 

Servants in the upper prison have been reassigned to one of the lower prison blocks. Remove the crank from the winch to the Great Door and place it in storage. 

It is critical that each of you report to the apothecary immediately to receive an inhibitor for the onset of Vitriscet. Once you have received your dose, report to the Warden. Any prisoners within your block not yet deemed fit for the Sump should be disregarded. Do not hesitate.

Gloria Vorrumos, Umbra Devorans"
important = true
metadata/_custom_type_script = "uid://c47e3n15issfv"
